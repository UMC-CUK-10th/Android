<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F3F3"
    android:fillViewport="true">

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:gravity="center_horizontal"
      android:paddingStart="24dp"
      android:paddingEnd="24dp"
      android:paddingTop="18dp"
      android:paddingBottom="32dp">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="20dp"
        android:layout_height="24dp"
        android:layout_gravity="start"
        android:layout_marginTop="6dp"
        android:src="@drawable/back"
        android:contentDescription="뒤로가기" />

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="오늘 하루는 어떠셨나요?"
        android:textColor="#111111"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtSubTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="감정우표를 선택해주세요"
        android:textColor="#222222"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/txtDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="선택한 감정우표를 기반으로 맞춤형 질문이 제공됩니다"
        android:textColor="#8A8A8A"
        android:textSize="11sp" />

    <LinearLayout
        android:id="@+id/btnHappy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clickable="true"
        android:focusable="true">

      <ImageView
          android:id="@+id/imgHappy"
          android:layout_width="58dp"
          android:layout_height="58dp"
          android:src="@drawable/happy"
          android:contentDescription="행복" />

      <TextView
          android:id="@+id/txtHappy"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="더없이 행복한 하루였어요"
          android:textColor="#111111"
          android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnExcited"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clickable="true"
        android:focusable="true">

      <ImageView
          android:id="@+id/imgExcited"
          android:layout_width="58dp"
          android:layout_height="58dp"
          android:src="@drawable/good"
          android:contentDescription="들뜸" />

      <TextView
          android:id="@+id/txtExcited"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="들뜨고 흥분돼요"
          android:textColor="#111111"
          android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clickable="true"
        android:focusable="true">

      <ImageView
          android:id="@+id/imgNormal"
          android:layout_width="58dp"
          android:layout_height="58dp"
          android:src="@drawable/soso"
          android:contentDescription="평범" />

      <TextView
          android:id="@+id/txtNormal"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="평범한 하루였어요"
          android:textColor="#111111"
          android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnAnxious"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clickable="true"
        android:focusable="true">

      <ImageView
          android:id="@+id/imgAnxious"
          android:layout_width="58dp"
          android:layout_height="58dp"
          android:src="@drawable/bad"
          android:contentDescription="불안" />

      <TextView
          android:id="@+id/txtAnxious"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="생각이 많아지고 불안해요"
          android:textColor="#111111"
          android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnAngry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clickable="true"
        android:focusable="true">

      <ImageView
          android:id="@+id/imgAngry"
          android:layout_width="58dp"
          android:layout_height="58dp"
          android:src="@drawable/angry"
          android:contentDescription="화남" />

      <TextView
          android:id="@+id/txtAngry"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="부글부글 화가 나요"
          android:textColor="#111111"
          android:textSize="16sp" />
    </LinearLayout>

  </LinearLayout>
</ScrollView>